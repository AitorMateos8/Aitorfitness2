    <a href="https://wa.me/34693588592?text=Quiero%20el%20plan%20basico">
      <button class="btn">Contratar</button>
    </a>
  </div>

  <div class="card">
    <h3>Plan Personalizado</h3>
    <p class="price">15€/mes</p>
    <p>Entrenamiento + dieta + seguimiento completo</p>
    <a href="https://wa.me/34693588592?text=Quiero%20el%20plan%20personalizado">
      <button class="btn">Contratar</button>
    </a>
  </div>

</section>

<section id="contacto">
  <h2>Contacto</h2>
  <p style="text-align:center">Habla conmigo directamente y empezamos hoy</p>
  <div style="text-align:center">
    <a href="https://wa.me/34693588592?text=Hola%20quiero%20info">
      <button class="btn">WhatsApp</button>
    </a>
  </div>
</section>

<footer style="text-align:center; padding:20px; background:#000;">
  <p>© 2026 Aitor Fitness</p>
</footer>

</body>
</html>
