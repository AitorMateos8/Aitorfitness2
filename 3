<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aitor Fitness</title>
  <style>
    body {font-family: Arial; margin:0; background:#0d0d0d; color:#fff;}
    header {background:#000; padding:20px; text-align:center; position:sticky; top:0;}
    nav a {color:#fff; margin:0 15px; text-decoration:none; font-weight:bold;}
    section {padding:60px 20px; max-width:900px; margin:auto;}
    h1,h2 {text-align:center;}
    .btn {background:#00ff88; color:#000; padding:12px 25px; border:none; cursor:pointer; border-radius:8px; font-weight:bold;}
    .card {background:#1a1a1a; padding:25px; margin:20px 0; border-radius:15px; box-shadow:0 0 10px rgba(0,0,0,0.5);} 
    .hero {text-align:center; padding:80px 20px; background:linear-gradient(black, #111);} 
    .price {font-size:24px; font-weight:bold; margin:10px 0;} 
  </style>
</head>
<body>

<header>
  <h1>Aitor Fitness</h1>
  <nav>
    <a href="#gratis">Gratis</a>
    <a href="#premium">Premium</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<section class="hero">
  <h2>Transforma tu físico en serio</h2>
  <p>Entrenamiento personalizado, seguimiento real y resultados visibles</p>
  <a href="https://wa.me/34693588592?text=Hola%20quiero%20empezar">
    <button class="btn">Empezar ahora</button>
  </a>
</section>

<section id="gratis">
  <h2>Rutinas Gratis</h2>
  <div class="card">
    <h3>Rutina Full Body</h3>
    <p>Entrena 3 días a la semana y mejora tu base</p>
    <a href="https://wa.me/34693588592?text=Quiero%20la%20rutina%20gratis">
      <button class="btn">Pedir rutina</button>
    </a>
  </div>
</section>

<section id="premium">
